{
  "name": "simplecmp/service-db-reference",
  "description": "Minimal PHP+SQLite reference implementation of the SimpleCMP Service DB protocol (REQ-8 / ADR-0005).",
  "type": "project",
  "license": "BSD-3-Clause",
  "require": {
    "php": ">=8.3",
    "ext-pdo": "*",
    "ext-pdo_sqlite": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "SimpleCmp\\ServiceDb\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SimpleCmp\\ServiceDb\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --testdox tests"
  }
}
